{
  "entities": {
    "userProfile": {
      "title": "User Profile",
      "description": "User wallet, joined instances and bank details",
      "type": "object",
      "properties": {
        "coins": { "type": "number" },
        "joinedTournaments": {
          "type": "array",
          "items": { "type": "number" }
        },
        "joinedMatches": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "bankDetails": {
          "type": "object",
          "properties": {
            "accountName": { "type": "string" },
            "bankAccount": { "type": "string" },
            "ifscCode": { "type": "string" },
            "mobileNumber": { "type": "string" }
          }
        }
      }
    },
    "cricketMatch": {
      "title": "Cricket Match",
      "description": "Admin configured cricket matches",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "team1": { 
          "type": "object", 
          "properties": { "name": { "type": "string" }, "short": { "type": "string" } }
        },
        "team2": { 
          "type": "object", 
          "properties": { "name": { "type": "string" }, "short": { "type": "string" } }
        },
        "title": { "type": "string" },
        "time": { "type": "string" },
        "entryFee": { "type": "number" },
        "status": { "type": "string" },
        "winningTeam": { "type": "string" },
        "liveDetails": {
          "type": "object",
          "properties": {
            "team1Score": { "type": "string" },
            "team2Score": { "type": "string" },
            "commentary": { "type": "string" }
          }
        }
      },
      "required": ["id", "title", "time", "entryFee", "status"]
    },
    "tournament": {
      "title": "Tournament Room",
      "description": "Admin configured tournament eSports rooms",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "game": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "entryFee": { "type": "number" },
        "perKill": { "type": "number" },
        "prizePool": { "type": "number" },
        "matchType": { "type": "string" },
        "map": { "type": "string" },
        "status": { "type": "string" },
        "totalSlots": { "type": "number" },
        "joinedPlayers": { "type": "array", "items": { "type": "string" } },
        "roomDetails": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "password": { "type": "string" }
          }
        },
        "streamLink": { "type": "string" },
        "results": { "type": "array" }
      },
      "required": ["id", "title", "date", "time", "entryFee", "status"]
    },
    "quizConfig": {
      "title": "Quiz Config",
      "description": "Admin configured quiz",
      "type": "object",
      "properties": {
        "entryFee": { "type": "number" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "number" },
              "q": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctIdx": { "type": "number" }
            }
          }
        }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/userProfile" },
      "description": "User profile containing wallet and joined states"
    },
    "/cricketMatches/{matchId}": {
      "schema": { "$ref": "#/entities/cricketMatch" },
      "description": "Cricket matches"
    },
    "/tournaments/{tournamentId}": {
      "schema": { "$ref": "#/entities/tournament" },
      "description": "Tournament match rooms"
    },
    "/global/quizConfig": {
      "schema": { "$ref": "#/entities/quizConfig" },
      "description": "Global Quiz Configuration"
    }
  }
}
